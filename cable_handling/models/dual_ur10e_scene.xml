<mujoco model="dual_ur10e_wire_harness">
  <!--
    Dual UR10e Wire Harness Assembly Scene
    
    Structure:
    - Robot assembly is attached programmatically via MjSpec API in simulation.py
    - This allows single robot_assembly.xml to be instantiated with left/ and right/ prefixes
    - Table: INCLUDED from table_with_connectors.xml
    - Cable: intentionally excluded (kinematic-only visualization)
  -->
  
  <compiler angle="radian" meshdir="../mujoco_menagerie/universal_robots_ur10e/assets" autolimits="true"/>

  <!-- OPTIMIZED Physics options for stable grasping -->
  <option integrator="implicitfast" solver="Newton" cone="elliptic" impratio="10" 
          timestep="0.002" iterations="40" tolerance="1e-8" noslip_iterations="2">
    <!-- noslip_iterations helps prevent slipping during grasp -->
    <flag warmstart="enable"/>
  </option>
  
  <!-- Size parameters for solver - increased for complex contacts -->
  <size nconmax="4000" njmax="8000"/>

  <statistic center="0.0 0.0 0.85" extent="3.5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-45" offwidth="1280" offheight="720"/>
    <quality shadowsize="4096"/>
  </visual>

  <!-- ========== DEFAULTS ========== -->
  <default>
    <default class="table">
      <geom type="box" rgba="0.6 0.45 0.3 1"/>
    </default>
  </default>

  <!-- ========== ASSETS ========== -->
  <asset>
    <!-- Environment textures -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <!-- Table materials -->
    <material name="table_wood" rgba="0.6 0.45 0.3 1" specular="0.2" shininess="0.1"/>
    <material name="table_metal" rgba="0.5 0.5 0.5 1" specular="0.5" shininess="0.3"/>
    <material name="connector_blue" rgba="0.2 0.3 0.8 1"/>
    <material name="connector_green" rgba="0.2 0.7 0.3 1"/>
    <material name="connector_yellow" rgba="0.9 0.8 0.1 1"/>
    <material name="cable_holder" rgba="0.3 0.3 0.3 1"/>
  </asset>

  <worldbody>
    <!-- Lighting -->
    <light pos="0 0 2.5" dir="0 0 -1" directional="true" castshadow="true"/>
    <light pos="1 1 2" dir="-0.5 -0.5 -1" diffuse="0.4 0.4 0.4"/>
    <light pos="-1 1 2" dir="0.5 -0.5 -1" diffuse="0.4 0.4 0.4"/>
    
    <!-- Ground plane -->
    <geom name="floor" size="3 3 0.05" type="plane" material="groundplane"/>
    
    <!-- Overview cameras -->
    <camera name="overview" pos="0 -2 1.8" xyaxes="1 0 0 0 0.5 1"/>
    <camera name="top_down" pos="0 0 2.5" euler="0 0 0" mode="fixed"/>
    <camera name="front_view" pos="0 -1.5 1" euler="1.3 0 0"/>

    <!-- Robot mount frames - robots attached programmatically with prefixes -->
    <frame name="left_robot_mount" pos="-0.6 0 0.75" quat="0.707 0 0 0.707"/>
    <frame name="right_robot_mount" pos="0.6 0 0.75" quat="0.707 0 0 -0.707"/>

    <!-- ========== TABLE (included from separate file) ========== -->
    <include file="table_with_connectors.xml"/>

  </worldbody>
</mujoco>
