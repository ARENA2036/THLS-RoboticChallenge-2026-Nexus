<?xml version="1.0"?>
<!--
  UR10e + Robotiq 2F-85 kinematic model for Pinocchio IK.

  Derived from:
    cable_handling/mujoco_menagerie/universal_robots_ur10e/ur10e.xml
    cable_handling/models/robot_assembly.xml

  No visual meshes.  Kinematic chain and joint limits only.
  TCP frame ("tcp_frame") is at the gripper fingertip center.

  Note: robot_assembly.xml uses identity base rotation (no quat on base
  body), so no extra base rotation is needed here.  Pinocchio FK matches
  MuJoCo FK for identical joint angles when using this URDF.
-->
<robot name="ur10e_robotiq2f85">

  <!-- ============================================================ -->
  <!-- Base                                                          -->
  <!-- ============================================================ -->

  <link name="base_link">
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00611" iyy="0.00611" izz="0.01125"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- Joint 1: shoulder_pan (Z-axis)                                -->
  <!-- MJCF: shoulder_link pos="0 0 0.181", axis="0 0 1"            -->
  <!-- ============================================================ -->

  <link name="shoulder_link">
    <inertial>
      <mass value="7.778"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0315" iyy="0.0315" izz="0.0219"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.181" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="330" velocity="2.094"/>
  </joint>

  <!-- ============================================================ -->
  <!-- Joint 2: shoulder_lift (Y-axis)                               -->
  <!-- MJCF: upper_arm_link pos="0 0.176 0" quat="1 0 1 0"         -->
  <!--        quat "1 0 1 0" normalised → 90 deg about Y            -->
  <!-- ============================================================ -->

  <link name="upper_arm_link">
    <inertial>
      <mass value="12.93"/>
      <origin xyz="0 0 0.3065" rpy="0 0 0"/>
      <inertia ixx="0.4231" iyy="0.4231" izz="0.0364"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0.176 0" rpy="0 1.5707963267948966 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28319" upper="6.28319" effort="330" velocity="2.094"/>
  </joint>

  <!-- ============================================================ -->
  <!-- Joint 3: elbow (Y-axis)                                      -->
  <!-- MJCF: forearm_link pos="0 -0.137 0.613"                      -->
  <!-- ============================================================ -->

  <link name="forearm_link">
    <inertial>
      <mass value="3.87"/>
      <origin xyz="0 0 0.2855" rpy="0 0 0"/>
      <inertia ixx="0.1106" iyy="0.1106" izz="0.0109"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 -0.137 0.613" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1415" upper="3.1415" effort="150" velocity="3.141"/>
  </joint>

  <!-- ============================================================ -->
  <!-- Joint 4: wrist_1 (Y-axis)                                    -->
  <!-- MJCF: wrist_1_link pos="0 0 0.571" quat="1 0 1 0"           -->
  <!-- ============================================================ -->

  <link name="wrist_1_link">
    <inertial>
      <mass value="1.96"/>
      <origin xyz="0 0.135 0" rpy="0 0 0"/>
      <inertia ixx="0.00551" iyy="0.00511" izz="0.00511"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <origin xyz="0 0 0.571" rpy="0 1.5707963267948966 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28319" upper="6.28319" effort="56" velocity="3.141"/>
  </joint>

  <!-- ============================================================ -->
  <!-- Joint 5: wrist_2 (Z-axis)                                    -->
  <!-- MJCF: wrist_2_link pos="0 0.135 0"                           -->
  <!-- ============================================================ -->

  <link name="wrist_2_link">
    <inertial>
      <mass value="1.96"/>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <inertia ixx="0.00551" iyy="0.00511" izz="0.00511"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <origin xyz="0 0.135 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="56" velocity="3.141"/>
  </joint>

  <!-- ============================================================ -->
  <!-- Joint 6: wrist_3 (Y-axis)                                    -->
  <!-- MJCF: wrist_3_link pos="0 0 0.12"                            -->
  <!-- ============================================================ -->

  <link name="wrist_3_link">
    <inertial>
      <mass value="0.202"/>
      <origin xyz="0 0.092 0" rpy="0 0 0"/>
      <inertia ixx="0.000205" iyy="0.000144" izz="0.000144"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/>
    <child link="wrist_3_link"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28319" upper="6.28319" effort="56" velocity="3.141"/>
  </joint>

  <!-- ============================================================ -->
  <!-- Fixed chain: wrist_3 → FTS → gripper_base → TCP              -->
  <!-- ============================================================ -->

  <!-- MJCF: fts_link pos="0 0.1 0" quat="-1 1 0 0" → -90 deg X   -->
  <link name="fts_link">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="fts_fixed_joint" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="fts_link"/>
    <origin xyz="0 0.1 0" rpy="-1.5707963267948966 0 0"/>
  </joint>

  <!-- MJCF: gripper_base pos="0 0 0.03" (child of fts_link)        -->
  <link name="gripper_base_link">
    <inertial>
      <mass value="0.777"/>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <inertia ixx="0.00026" iyy="0.000225" izz="0.000153"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="gripper_base_fixed_joint" type="fixed">
    <parent link="fts_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
  </joint>

  <!-- MJCF: tcp_site pos="0 0 0.16" on gripper_base                -->
  <link name="tcp_frame">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-9" iyy="1e-9" izz="1e-9"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="tcp_fixed_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="tcp_frame"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
  </joint>

</robot>
